<?xml version="1.0" encoding="utf-8"?>
<android.zero.studio.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 1. 主体内容区域 -->
        <RelativeLayout
            android:id="@+id/activity_termux_root_relative_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="24dp">

            <android.zero.studio.terminal.ui.tabs.TerminalSessionTabsView
                android:id="@+id/terminal_tabs_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true" />

            <com.termux.view.TerminalView
                android:id="@+id/terminal_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/terminal_tabs_view"
                android:defaultFocusHighlightEnabled="false"
                android:focusableInTouchMode="true"
                android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                android:scrollbars="vertical"
                android:importantForAutofill="no"
                android:autofillHints="password"
                tools:ignore="UnusedAttribute" />

            <LinearLayout
                android:id="@+id/terminal_empty_state_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/terminal_tabs_view"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone"
                android:background="?attr/colorSurface">

                <TextView
                    android:id="@+id/terminal_empty_state_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前没有终端会话，请先创建一个新会话。"
                    android:textAlignment="center"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/terminal_empty_state_new_session_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新建会话" />
            </LinearLayout>

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/bottom_sheet_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            app:behavior_hideable="false"
            app:behavior_peekHeight="18dp">

            <com.itsaky.androidide.ui.EdgeSnapBubbleView
                android:id="@+id/terminal_toolbar_gesture_bubble"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:background="@android:color/transparent" />

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/terminal_toolbar_view_pager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurface" />

        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="0.0001dp"
        android:visibility="gone"
        android:background="@android:color/transparent" />

</android.zero.studio.terminal.TermuxActivityRootView>
